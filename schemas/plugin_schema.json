{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/Significant-Gravitas/AutoAI/master/schemas/plugin_schema.json",
  "$comment": "Example: {\"name\": \"Translator\", \"version\": \"1.0.0\", \"description\": \"Translates text\", \"author\": \"AutoAI\", \"inputs\": [{\"name\": \"text\", \"type\": \"string\", \"description\": \"Text to translate\"}], \"outputs\": [{\"name\": \"translation\", \"type\": \"string\", \"description\": \"Translated text\"}] }",
  "title": "Plugin Metadata Schema",
  "type": "object",
  "required": ["name", "version", "description", "author"],
  "properties": {
    "name": {"type": "string"},
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "description": {"type": "string"},
    "author": {"type": "string"},
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": {"type": "string"},
          "type": {"type": "string"},
          "description": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": {"type": "string"},
          "type": {"type": "string"},
          "description": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
