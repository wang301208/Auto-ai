{
  "name": "local-agent-tui",
  "version": "0.1.0",
  "type": "module",
  "description": "Terminal UI for the local agent runtime",
  "main": "dist/entry.js",
  "scripts": {
    "dev": "tsx watch src/entry.tsx",
    "start": "node dist/entry.js",
    "build": "tsc",
    "lint": "eslint src --ext .ts,.tsx",
    "fmt": "prettier --write src",
    "test": "vitest"
  },
  "dependencies": {
    "@nanostores/react": "^1.1.0",
    "ink": "^4.4.1",
    "ink-text-input": "^5.0.1",
    "nanostores": "^1.3.0",
    "react": "^18.2.0",
    "use-subscription": "^1.8.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "prettier": "^3.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
