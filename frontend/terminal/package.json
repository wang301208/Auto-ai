{
  "name": "autogpt-terminal",
  "version": "1.0.0",
  "description": "AutoGPT智能终端 - 具有意识和情绪表达能力的交互界面",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.tsx",
    "build": "tsup src/index.tsx --format esm --clean --sourcemap --dts --minify",
    "start": "node dist/index.js",
    "check": "tsc --noEmit",
    "test": "vitest",
    "coverage": "vitest run --coverage"
  },
  "keywords": [
    "autogpt",
    "terminal",
    "tui",
    "react",
    "ink"
  ],
  "author": "AutoGPT Team",
  "license": "MIT",
  "dependencies": {
    "@nanostores/react": "^1.1.0",
    "ink": ">=4.4.1",
    "ink-text-input": "^5.0.1",
    "nanostores": ">=1.3.0",
    "react": ">=18.0.0",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^25.8.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitest/coverage-v8": "^1.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "ink": ">=4.4.1",
    "nanostores": ">=1.3.0",
    "react": ">=18.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ]
}
